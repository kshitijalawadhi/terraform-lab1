# Terraform directories
.terraform/
# Terraform state files
*.tfstate
*.tfstate.*
# Crash logs
crash.log
# Exclude sensitive variable files
*.tfvars
*.tfvars.json
# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Terraform CLI config files
.terraformrc
terraform.rc
# Plan files
*.tfplan
# Lock file (optional: include or exclude based on team policy)
.terraform.lock.hcl
